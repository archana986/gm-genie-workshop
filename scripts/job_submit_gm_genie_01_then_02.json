{
  "run_name": "gm_genie_workshop_01_then_02_serverless",
  "timeout_seconds": 7200,
  "tasks": [
    {
      "task_key": "setup_data",
      "environment_key": "default",
      "notebook_task": {
        "notebook_path": "/Workspace/Shared/gm-genie-workshop/01_setup_data",
        "source": "WORKSPACE"
      }
    },
    {
      "task_key": "create_genie_spaces",
      "environment_key": "default",
      "depends_on": [{ "task_key": "setup_data" }],
      "notebook_task": {
        "notebook_path": "/Workspace/Shared/gm-genie-workshop/02_create_genie_spaces",
        "source": "WORKSPACE"
      }
    }
  ],
  "environments": [
    {
      "environment_key": "default",
      "spec": {
        "client": "1"
      }
    }
  ]
}
